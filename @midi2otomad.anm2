--track@dangle:Δ角度,-3600,3600,0,0.1
--track@blur:ぼかし,0,2000,1,1
--track@dblur:Δぼかし,0,2000,1,1
--track@width:幅,-2000,2000,0,1
--track@dwidth:Δ幅,-2000,2000,0,1
--group:M2O共通項目,true
--track@length:時間(拍),0,10,1,0.01
--check@isNorm:正規化,false
--track@delayIndex:カウントずらし,-100,100,0,1
--select@easing:イージング=1,直線=1,∧三角波=2,」二次関数イン=3,「二次関数アウト=4,∧二次関数往復=5,」三次関数イン=6,「三次関数アウト=7,∧三次関数往復=8,」多項式イン=9,「多項式アウト=10,∧多項式往復=11,」指数関数イン=12,「指数関数アウト=13,∧指数関数往復=14,」サインイン=15,「コサインアウト=16,∧サイン往復=17
--track@amplitude:勢い,0,40,4,0.01
--check@isDecaying:減衰,1
--check@isAlternating:交互反転,0
--file@pathMidi:参照MIDI上書

local O = Akto.MidiToOtomad
local M = O.MidiToAnimator
local L = O.MidiToAnalyzer

local a,b,c,d = O.loadBufferLatestNote(pathMidi)
a = a + delayIndex
local sign = 1-2*(isAlternating*a%2)
local anim = isNorm and c or b
anim = (length == 0) and 1 or anim/length --if length is 0, finish immediately; else, anim is squished by length
local progress = isDecaying+(1-2*isDecaying)*(M.ease[easing](math.min(1, anim), amplitude))

obj.effect("斜めクリッピング",
"中心X", cx + dcx*progress*sign,
"中心Y", cy + dcy*progress*sign,
